{
  "name": "Dark Morandi",
  "type": "dark",
  "colors": {
    "focusBorder": "#4C6176",
    "foreground": "#EDEFF3",
    "editor.background": "#12151C",
    "editor.foreground": "#EDEFF3",
    "editor.selectionBackground": "#26384A80",
    "editor.lineHighlightBackground": "#181B2199",
    "editorCursor.foreground": "#4C7AA9",
    "editorWhitespace.foreground": "#3B424E66",
    "editorIndentGuide.background": "#3B424E88",
    "editorIndentGuide.activeBackground": "#4C6176",
    "editorLineNumber.foreground": "#9E92AAAA",
    "editorLineNumber.activeForeground": "#587E6E",
    "editorBracketMatch.background": "#26384A55",
    "editorBracketMatch.border": "#4C7AA9",
    "sideBar.background": "#15181E",
    "sideBar.foreground": "#EAEDF1",
    "sideBar.border": "#3B424E",
    "sideBarTitle.foreground": "#EDEFF3",
    "activityBar.background": "#181B21",
    "activityBar.foreground": "#4C7AA9",
    "activityBar.border": "#3B424E",
    "activityBarBadge.background": "#4C7AA9",
    "activityBarBadge.foreground": "#15181E",
    "titleBar.activeBackground": "#181B21",
    "titleBar.activeForeground": "#EDEFF3",
    "titleBar.inactiveBackground": "#15181E",
    "titleBar.inactiveForeground": "#9E92AA",
    "statusBar.background": "#181B21",
    "statusBar.foreground": "#8C94A1",
    "statusBar.border": "#3B424E",
    "tab.activeBackground": "#12151C",
    "tab.activeForeground": "#EDEFF3",
    "tab.inactiveBackground": "#1D2025",
    "tab.inactiveForeground": "#3E6B98",
    "tab.border": "#3B424E",
    "editorGroupHeader.tabsBackground": "#181B21",
    "panel.background": "#181B21",
    "panel.border": "#3B424E",
    "terminal.background": "#12151C",
    "terminal.foreground": "#EDEFF3",
    "terminal.ansiBlack": "#12151C",
    "terminal.ansiRed": "#4C7AA9",
    "terminal.ansiGreen": "#587E6E",
    "terminal.ansiYellow": "#593647",
    "terminal.ansiBlue": "#3E6B98",
    "terminal.ansiMagenta": "#97C4B1",
    "terminal.ansiCyan": "#9E92AA",
    "terminal.ansiWhite": "#EDEFF3",
    "input.background": "#1E2229",
    "input.foreground": "#FFFFFF",
    "input.border": "#4C6176",
    "inputOption.activeBorder": "#4C7AA9",
    "dropdown.background": "#1E2229",
    "dropdown.foreground": "#FFFFFF",
    "dropdown.border": "#4C6176",
    "list.activeSelectionBackground": "#26384A",
    "list.activeSelectionForeground": "#EDEFF3",
    "list.inactiveSelectionBackground": "#1D2025",
    "list.hoverBackground": "#1D2026",
    "list.focusOutline": "#4C7AA9",
    "badge.background": "#4C7AA9",
    "badge.foreground": "#15181E",
    "button.background": "#4C7AA9",
    "button.foreground": "#15181E",
    "button.hoverBackground": "#4D759D",
    "scrollbarSlider.background": "#4C617666",
    "scrollbarSlider.hoverBackground": "#4C617699",
    "scrollbarSlider.activeBackground": "#4C7AA9AA",
    "minimap.selectionHighlight": "#26384AAA",
    "gitDecoration.modifiedResourceForeground": "#C9A84C",
    "gitDecoration.deletedResourceForeground": "#D08888",
    "gitDecoration.untrackedResourceForeground": "#7DB89A",
    "peekView.border": "#4C6176",
    "peekViewEditor.background": "#181D25",
    "peekViewTitle.background": "#181B21",
    "widget.shadow": "#07090D55"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9E92AA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#608F7B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#97C4B1"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5787B7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#4C84BD"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#97C4B1"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#EAEDF1"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#5389C0"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#5787B7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4C84BD"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#5787B7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#F3F5F7",
        "background": "#181D2544"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    }
  ]
}
