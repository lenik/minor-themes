{
  "name": "Dark Maiden",
  "type": "dark",
  "colors": {
    "focusBorder": "#6F5252",
    "foreground": "#EDEFF3",
    "editor.background": "#12151C",
    "editor.foreground": "#EDEFF3",
    "editor.selectionBackground": "#41303C80",
    "editor.lineHighlightBackground": "#181B2199",
    "editorCursor.foreground": "#A06A6A",
    "editorWhitespace.foreground": "#3B424E66",
    "editorIndentGuide.background": "#3B424E88",
    "editorIndentGuide.activeBackground": "#6F5252",
    "editorLineNumber.foreground": "#A795A2AA",
    "editorLineNumber.activeForeground": "#566C5B",
    "editorBracketMatch.background": "#41303C55",
    "editorBracketMatch.border": "#A06A6A",
    "sideBar.background": "#15181E",
    "sideBar.foreground": "#EAEDF1",
    "sideBar.border": "#3B424E",
    "sideBarTitle.foreground": "#EDEFF3",
    "activityBar.background": "#181B21",
    "activityBar.foreground": "#A06A6A",
    "activityBar.border": "#3B424E",
    "activityBarBadge.background": "#A06A6A",
    "activityBarBadge.foreground": "#15181E",
    "titleBar.activeBackground": "#181B21",
    "titleBar.activeForeground": "#EDEFF3",
    "titleBar.inactiveBackground": "#15181E",
    "titleBar.inactiveForeground": "#A795A2",
    "statusBar.background": "#181B21",
    "statusBar.foreground": "#8C94A1",
    "statusBar.border": "#3B424E",
    "tab.activeBackground": "#12151C",
    "tab.activeForeground": "#EDEFF3",
    "tab.inactiveBackground": "#1D2025",
    "tab.inactiveForeground": "#6A5865",
    "tab.border": "#3B424E",
    "editorGroupHeader.tabsBackground": "#181B21",
    "panel.background": "#181B21",
    "panel.border": "#3B424E",
    "terminal.background": "#12151C",
    "terminal.foreground": "#EDEFF3",
    "terminal.ansiBlack": "#12151C",
    "terminal.ansiRed": "#A06A6A",
    "terminal.ansiGreen": "#566C5B",
    "terminal.ansiYellow": "#796215",
    "terminal.ansiBlue": "#6A5865",
    "terminal.ansiMagenta": "#DDC05F",
    "terminal.ansiCyan": "#A795A2",
    "terminal.ansiWhite": "#EDEFF3",
    "input.background": "#1E2229",
    "input.foreground": "#FFFFFF",
    "input.border": "#6F5252",
    "inputOption.activeBorder": "#A06A6A",
    "dropdown.background": "#1E2229",
    "dropdown.foreground": "#FFFFFF",
    "dropdown.border": "#6F5252",
    "list.activeSelectionBackground": "#41303C",
    "list.activeSelectionForeground": "#EDEFF3",
    "list.inactiveSelectionBackground": "#1D2025",
    "list.hoverBackground": "#1D2026",
    "list.focusOutline": "#A06A6A",
    "badge.background": "#A06A6A",
    "badge.foreground": "#15181E",
    "button.background": "#A06A6A",
    "button.foreground": "#15181E",
    "button.hoverBackground": "#CAA52B",
    "scrollbarSlider.background": "#6F525266",
    "scrollbarSlider.hoverBackground": "#6F525299",
    "scrollbarSlider.activeBackground": "#A06A6AAA",
    "minimap.selectionHighlight": "#41303CAA",
    "gitDecoration.modifiedResourceForeground": "#796215",
    "gitDecoration.deletedResourceForeground": "#A06A6A",
    "gitDecoration.untrackedResourceForeground": "#566C5B",
    "peekView.border": "#6F5252",
    "peekViewEditor.background": "#181D25",
    "peekViewTitle.background": "#181B21",
    "widget.shadow": "#07090D55"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A795A2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#688D70"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#DDC05F"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#AC7777"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9A758F"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#DDC05F"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#EAEDF1"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E84162"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#AC7777"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9A758F"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#AC7777",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#F3F5F7",
        "background": "#181D2544"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    }
  ]
}
