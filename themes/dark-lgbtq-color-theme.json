{
  "name": "Dark LGBTQ",
  "type": "dark",
  "colors": {
    "focusBorder": "#535C6E",
    "foreground": "#EDEFF3",
    "editor.background": "#12151C",
    "editor.foreground": "#EDEFF3",
    "editor.selectionBackground": "#1F514180",
    "editor.lineHighlightBackground": "#181B2199",
    "editorCursor.foreground": "#7F28BD",
    "editorWhitespace.foreground": "#3B424E66",
    "editorIndentGuide.background": "#3B424E88",
    "editorIndentGuide.activeBackground": "#535C6E",
    "editorLineNumber.foreground": "#9499A8AA",
    "editorLineNumber.activeForeground": "#279B57",
    "editorBracketMatch.background": "#1F514155",
    "editorBracketMatch.border": "#7F28BD",
    "sideBar.background": "#15181E",
    "sideBar.foreground": "#EAEDF1",
    "sideBar.border": "#3B424E",
    "sideBarTitle.foreground": "#EDEFF3",
    "activityBar.background": "#181B21",
    "activityBar.foreground": "#7F28BD",
    "activityBar.border": "#3B424E",
    "activityBarBadge.background": "#7F28BD",
    "activityBarBadge.foreground": "#15181E",
    "titleBar.activeBackground": "#181B21",
    "titleBar.activeForeground": "#EDEFF3",
    "titleBar.inactiveBackground": "#15181E",
    "titleBar.inactiveForeground": "#9499A8",
    "statusBar.background": "#181B21",
    "statusBar.foreground": "#8C94A1",
    "statusBar.border": "#3B424E",
    "tab.activeBackground": "#12151C",
    "tab.activeForeground": "#EDEFF3",
    "tab.inactiveBackground": "#1D2025",
    "tab.inactiveForeground": "#156BC1",
    "tab.border": "#3B424E",
    "editorGroupHeader.tabsBackground": "#181B21",
    "panel.background": "#181B21",
    "panel.border": "#3B424E",
    "terminal.background": "#12151C",
    "terminal.foreground": "#EDEFF3",
    "terminal.ansiBlack": "#12151C",
    "terminal.ansiRed": "#7F28BD",
    "terminal.ansiGreen": "#279B57",
    "terminal.ansiYellow": "#8B7504",
    "terminal.ansiBlue": "#156BC1",
    "terminal.ansiMagenta": "#11B4D4",
    "terminal.ansiCyan": "#9499A8",
    "terminal.ansiWhite": "#EDEFF3",
    "input.background": "#1E2229",
    "input.foreground": "#FFFFFF",
    "input.border": "#535C6E",
    "inputOption.activeBorder": "#7F28BD",
    "dropdown.background": "#1E2229",
    "dropdown.foreground": "#FFFFFF",
    "dropdown.border": "#535C6E",
    "list.activeSelectionBackground": "#1F5141",
    "list.activeSelectionForeground": "#EDEFF3",
    "list.inactiveSelectionBackground": "#1D2025",
    "list.hoverBackground": "#1D2026",
    "list.focusOutline": "#7F28BD",
    "badge.background": "#7F28BD",
    "badge.foreground": "#15181E",
    "button.background": "#7F28BD",
    "button.foreground": "#15181E",
    "button.hoverBackground": "#DC1829",
    "scrollbarSlider.background": "#535C6E66",
    "scrollbarSlider.hoverBackground": "#535C6E99",
    "scrollbarSlider.activeBackground": "#7F28BDAA",
    "minimap.selectionHighlight": "#1F5141AA",
    "gitDecoration.modifiedResourceForeground": "#F5D742",
    "gitDecoration.deletedResourceForeground": "#D070F0",
    "gitDecoration.untrackedResourceForeground": "#3FD47A",
    "peekView.border": "#535C6E",
    "peekViewEditor.background": "#181D25",
    "peekViewTitle.background": "#181B21",
    "widget.shadow": "#07090D55"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9499A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#279B57"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#11B4D4"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B064E7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#1D84EC"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#11B4D4"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#EAEDF1"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#EA5110"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#B064E7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1D84EC"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#B064E7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#F3F5F7",
        "background": "#181D2544"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    }
  ]
}
