{
  "name": "Dark Lesbian",
  "type": "dark",
  "colors": {
    "focusBorder": "#705E51",
    "foreground": "#EDEFF3",
    "editor.background": "#12151C",
    "editor.foreground": "#EDEFF3",
    "editor.selectionBackground": "#511F2B80",
    "editor.lineHighlightBackground": "#181B2199",
    "editorCursor.foreground": "#BF2270",
    "editorWhitespace.foreground": "#3B424E66",
    "editorIndentGuide.background": "#3B424E88",
    "editorIndentGuide.activeBackground": "#705E51",
    "editorLineNumber.foreground": "#A6969EAA",
    "editorLineNumber.activeForeground": "#8E295C",
    "editorBracketMatch.background": "#511F2B55",
    "editorBracketMatch.border": "#BF2270",
    "sideBar.background": "#15181E",
    "sideBar.foreground": "#EAEDF1",
    "sideBar.border": "#3B424E",
    "sideBarTitle.foreground": "#EDEFF3",
    "activityBar.background": "#181B21",
    "activityBar.foreground": "#BF2270",
    "activityBar.border": "#3B424E",
    "activityBarBadge.background": "#BF2270",
    "activityBarBadge.foreground": "#15181E",
    "titleBar.activeBackground": "#181B21",
    "titleBar.activeForeground": "#EDEFF3",
    "titleBar.inactiveBackground": "#15181E",
    "titleBar.inactiveForeground": "#A6969E",
    "statusBar.background": "#181B21",
    "statusBar.foreground": "#8C94A1",
    "statusBar.border": "#3B424E",
    "tab.activeBackground": "#12151C",
    "tab.activeForeground": "#EDEFF3",
    "tab.inactiveBackground": "#1D2025",
    "tab.inactiveForeground": "#E05D06",
    "tab.border": "#3B424E",
    "editorGroupHeader.tabsBackground": "#181B21",
    "panel.background": "#181B21",
    "panel.border": "#3B424E",
    "terminal.background": "#12151C",
    "terminal.foreground": "#EDEFF3",
    "terminal.ansiBlack": "#12151C",
    "terminal.ansiRed": "#BF2270",
    "terminal.ansiGreen": "#8E295C",
    "terminal.ansiYellow": "#8B3A04",
    "terminal.ansiBlue": "#E05D06",
    "terminal.ansiMagenta": "#EE2B5B",
    "terminal.ansiCyan": "#A6969E",
    "terminal.ansiWhite": "#EDEFF3",
    "input.background": "#1E2229",
    "input.foreground": "#FFFFFF",
    "input.border": "#705E51",
    "inputOption.activeBorder": "#BF2270",
    "dropdown.background": "#1E2229",
    "dropdown.foreground": "#FFFFFF",
    "dropdown.border": "#705E51",
    "list.activeSelectionBackground": "#511F2B",
    "list.activeSelectionForeground": "#EDEFF3",
    "list.inactiveSelectionBackground": "#1D2025",
    "list.hoverBackground": "#1D2026",
    "list.focusOutline": "#BF2270",
    "badge.background": "#BF2270",
    "badge.foreground": "#15181E",
    "button.background": "#BF2270",
    "button.foreground": "#15181E",
    "button.hoverBackground": "#E9380C",
    "scrollbarSlider.background": "#705E5166",
    "scrollbarSlider.hoverBackground": "#705E5199",
    "scrollbarSlider.activeBackground": "#BF2270AA",
    "minimap.selectionHighlight": "#511F2BAA",
    "gitDecoration.modifiedResourceForeground": "#8B3A04",
    "gitDecoration.deletedResourceForeground": "#BF2270",
    "gitDecoration.untrackedResourceForeground": "#8E295C",
    "peekView.border": "#705E51",
    "peekViewEditor.background": "#181D25",
    "peekViewTitle.background": "#181B21",
    "widget.shadow": "#07090D55"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A6969E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#DC5A9C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#F2416C"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E64896"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#E05D06"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#F2416C"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#EAEDF1"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#EC471D"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#E64896"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E05D06"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E64896",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#F3F5F7",
        "background": "#181D2544"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    }
  ]
}
