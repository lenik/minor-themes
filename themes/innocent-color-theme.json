    "editorBracketMatch.background": "#EEEAF655",
    "editorBracketMatch.border": "#AF7994",
    "sideBar.background": "#FBF8F9",
    "sideBar.foreground": "#4F4455",
    "sideBar.border": "#E9E2E9",
