    "panel.background": "#F5F4EF",
    "panel.border": "#E1DED5",
    "terminal.background": "#FFFFFF",
    "terminal.foreground": "#3F1812",
    "terminal.ansiBlack": "#3F1812",
    "terminal.ansiRed": "#DD260E",
    "terminal.ansiGreen": "#8F2314",
    "terminal.ansiYellow": "#F5C3BC",
    "terminal.ansiBlue": "#EFB506",
    "terminal.ansiMagenta": "#AA2918",
