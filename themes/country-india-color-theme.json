    "scrollbarSlider.hoverBackground": "#D7C6B799",
    "scrollbarSlider.activeBackground": "#FA8D2EAA",
    "minimap.selectionHighlight": "#D4EDDCAA",
    "gitDecoration.modifiedResourceForeground": "#B5600A",
    "gitDecoration.deletedResourceForeground": "#C62828",
    "gitDecoration.untrackedResourceForeground": "#1B7A42",
    "peekView.border": "#D7C6B7",
    "peekViewEditor.background": "#ECF3EF",
    "peekViewTitle.background": "#EFF5F1",
    "widget.shadow": "#7D573655"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B6A5B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#1D4087"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#204897"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A84E00"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#078230"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#204897"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#67401E"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#A86224"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#A84E00"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#078230"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#A84E00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#634021",
        "background": "#ECF3EF33"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C62828"
      }
    }
  ]
}
