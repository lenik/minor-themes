    "tab.border": "#DDD9DA",
    "editorGroupHeader.tabsBackground": "#F3F1F1",
    "panel.background": "#F3F1F1",
    "panel.border": "#DDD9DA",
    "terminal.background": "#FFFFFF",
    "terminal.foreground": "#371013",
    "terminal.ansiBlack": "#371013",
    "terminal.ansiRed": "#BF1825",
    "terminal.ansiGreen": "#BD2835",
    "terminal.ansiYellow": "#F2C0C4",
    "terminal.ansiBlue": "#F5F4F4",
    "terminal.ansiMagenta": "#D7424E",
    "terminal.ansiCyan": "#7B5B5E",
    "terminal.ansiWhite": "#371013",
    "input.background": "#FFFFFF",
    "input.foreground": "#2F0E11",
    "input.border": "#D7B7BA",
    "inputOption.activeBorder": "#BF1825",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#2F0E11",
    "dropdown.border": "#D7B7BA",
    "list.activeSelectionBackground": "#E2DFDF",
    "list.activeSelectionForeground": "#371013",
    "list.inactiveSelectionBackground": "#EDE9E9",
    "list.hoverBackground": "#FDFCFC",
    "list.focusOutline": "#BF1825",
    "badge.background": "#BF1825",
    "badge.foreground": "#FFFFFF",
    "button.background": "#BF1825",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#C62A37",
    "scrollbarSlider.background": "#D7B7BA66",
    "scrollbarSlider.hoverBackground": "#D7B7BA99",
    "scrollbarSlider.activeBackground": "#BF1825AA",
    "minimap.selectionHighlight": "#E2DFDFAA",
    "gitDecoration.modifiedResourceForeground": "#8A6508",
    "gitDecoration.deletedResourceForeground": "#BF1825",
    "gitDecoration.untrackedResourceForeground": "#2D5E3A",
    "peekView.border": "#D7B7BA",
    "peekViewEditor.background": "#F1EEEF",
    "peekViewTitle.background": "#F3F1F1",
    "widget.shadow": "#7D363B55"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B5B5E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#BD2835"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#C62A37"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#BF1825"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B54F4F"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#C62A37"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#2F0E11"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#65151C"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#BF1825"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B54F4F"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#BF1825",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#361215",
        "background": "#F1EEEF33"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C62828"
      }
    }
  ]
}
