{
  "name": "Country: Canada",
  "type": "light",
  "colors": {
    "focusBorder": "#D7B7B7",
    "foreground": "#3B1111",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#3B1111",
    "editor.selectionBackground": "#E2DFDF66",
    "editor.lineHighlightBackground": "#F3F1F1CC",
    "editorCursor.foreground": "#E00606",
    "editorWhitespace.foreground": "#DDD9D966",
    "editorIndentGuide.background": "#DDD9D988",
    "editorIndentGuide.activeBackground": "#D7B7B7",
    "editorLineNumber.foreground": "#7B5B5BAA",
    "editorLineNumber.activeForeground": "#C32230",
    "editorBracketMatch.background": "#E2DFDF55",
    "editorBracketMatch.border": "#E00606",
    "sideBar.background": "#F8F7F7",
    "sideBar.foreground": "#330F0F",
    "sideBar.border": "#DDD9D9",
    "sideBarTitle.foreground": "#3B1111",
    "activityBar.background": "#F3F1F1",
    "activityBar.foreground": "#E00606",
    "activityBar.border": "#DDD9D9",
    "activityBarBadge.background": "#E00606",
    "activityBarBadge.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#F3F1F1",
    "titleBar.activeForeground": "#3B1111",
    "titleBar.inactiveBackground": "#F8F7F7",
    "titleBar.inactiveForeground": "#7B5B5B",
    "statusBar.background": "#F3F1F1",
    "statusBar.foreground": "#836767",
    "statusBar.border": "#DDD9D9",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#3B1111",
    "tab.inactiveBackground": "#EDE9E9",
    "tab.inactiveForeground": "#F5F4F4",
    "tab.border": "#DDD9D9",
    "editorGroupHeader.tabsBackground": "#F3F1F1",
    "panel.background": "#F3F1F1",
    "panel.border": "#DDD9D9",
    "terminal.background": "#FFFFFF",
    "terminal.foreground": "#3B1111",
    "terminal.ansiBlack": "#3B1111",
    "terminal.ansiRed": "#E00606",
    "terminal.ansiGreen": "#C32230",
    "terminal.ansiYellow": "#F4BEC2",
    "terminal.ansiBlue": "#F5F4F4",
    "terminal.ansiMagenta": "#DD3C49",
    "terminal.ansiCyan": "#7B5B5B",
    "terminal.ansiWhite": "#3B1111",
    "input.background": "#FFFFFF",
    "input.foreground": "#330F0F",
    "input.border": "#D7B7B7",
    "inputOption.activeBorder": "#E00606",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#330F0F",
    "dropdown.border": "#D7B7B7",
    "list.activeSelectionBackground": "#E2DFDF",
    "list.activeSelectionForeground": "#3B1111",
    "list.inactiveSelectionBackground": "#EDE9E9",
    "list.hoverBackground": "#FDFCFC",
    "list.focusOutline": "#E00606",
    "badge.background": "#E00606",
    "badge.foreground": "#FFFFFF",
    "button.background": "#E00606",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#CC2432",
    "scrollbarSlider.background": "#D7B7B766",
    "scrollbarSlider.hoverBackground": "#D7B7B799",
    "scrollbarSlider.activeBackground": "#E00606AA",
    "minimap.selectionHighlight": "#E2DFDFAA",
    "gitDecoration.modifiedResourceForeground": "#F4BEC2",
    "gitDecoration.deletedResourceForeground": "#E00606",
    "gitDecoration.untrackedResourceForeground": "#C32230",
    "peekView.border": "#D7B7B7",
    "peekViewEditor.background": "#F1EEEE",
    "peekViewTitle.background": "#F3F1F1",
    "widget.shadow": "#7D363655"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B5B5B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#C32230"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#CC2432"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E00606"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B54F4F"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#CC2432"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#330F0F"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#721818"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#E00606"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B54F4F"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E00606",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#361212",
        "background": "#F1EEEE33"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C62828"
      }
    }
  ]
}
